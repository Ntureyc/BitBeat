{
  "identifier": "default",
  "description": "Default capability for BitBeat",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-minimize",
    "core:window:allow-maximize",
    "core:window:allow-close",
    "core:window:allow-toggle-maximize",
    "core:window:allow-set-focus",
    "dialog:default",
    "dialog:allow-open",
    "fs:default",
    "fs:read-all"
  ]
}
